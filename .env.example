# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# EmailJS Configuration
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
VITE_EMAILJS_SERVICE_ID=gmail_service
VITE_EMAILJS_TEMPLATE_ID=contact_form_template

# Admin Panel (client-side, use strong credentials)
VITE_ADMIN_USERNAME=your_admin_username
VITE_ADMIN_PASSWORD=your_secure_password

# Google Analytics (optional, defaults to site ID if omitted)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ------------------------------------------------------------------
# Newsletter (Brevo) - SERVER-SIDE ONLY. Set these in Vercel Project
# Settings > Environment Variables. Do NOT use the VITE_ prefix, or the
# keys would be exposed in the browser bundle. Used by /api/subscribe
# and /api/broadcast. Without them, subscribers are still saved to
# Firebase (visible in the admin Newsletter tab), but no emails are sent.
# ------------------------------------------------------------------
BREVO_API_KEY=your_brevo_api_v3_key
BREVO_LIST_ID=your_brevo_list_id
BREVO_SENDER_EMAIL=verified_sender@yourdomain.com
BREVO_SENDER_NAME=Beta-Tech Labs
# Secret passphrase you type in the admin panel to authorize sending a newsletter
NEWSLETTER_ADMIN_KEY=choose_a_strong_secret
